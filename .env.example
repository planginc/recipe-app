# ============================================================
# Recipe App — Environment Configuration
# Copy this file to .env.local and fill in your values.
# ============================================================

# ---- Choose your backend ----
# Set to "supabase" or "convex"
VITE_DB_BACKEND=supabase

# ---- Your Telegram ID ----
# Used to associate your data with your JJ instance.
# Find yours by messaging @userinfobot on Telegram.
VITE_USER_TELEGRAM_ID=your_telegram_id_here


# ============================================================
# SUPABASE BACKEND (skip this section if using Convex)
# Get these from: supabase.com/dashboard → Project → Settings → API
# ============================================================
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# AI endpoints — your deployed Supabase edge function URLs
VITE_AI_CHAT_URL=https://YOUR_PROJECT_ID.supabase.co/functions/v1/recipe-ai-suggest
VITE_AUTO_TAG_URL=https://YOUR_PROJECT_ID.supabase.co/functions/v1/auto-tag-recipe


# ============================================================
# CONVEX BACKEND (skip this section if using Supabase)
# Get VITE_CONVEX_URL from: dashboard.convex.dev → your project → Settings
# ============================================================
VITE_CONVEX_URL=https://YOUR_DEPLOYMENT.convex.cloud

# AI endpoints — derived from your Convex site URL
# Replace .convex.cloud with .convex.site to get the HTTP action URL
VITE_AI_CHAT_URL=https://YOUR_DEPLOYMENT.convex.site/recipeAiSuggest
VITE_AUTO_TAG_URL=https://YOUR_DEPLOYMENT.convex.site/autoTagRecipe
